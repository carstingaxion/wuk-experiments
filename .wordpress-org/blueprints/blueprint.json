{
  "$schema": "https://playground.wordpress.net/blueprint-schema.json",
  "preferredVersions": {
    "php": "8.2",
    "wp": "latest"
  },
  "features": {
    "networking": true
  },
  "landingPage": "/",
  "steps": [
    {
      "step": "setSiteLanguage",
      "language": "de_DE"
    },
    {
      "step": "setSiteOptions",
      "options": {
        "blogname": "WUK experiments",
        "blogdescription": "wuk xp",
        "wordpress_export_to_server__owner_repo_branch": "carstingaxion/wuk-experiments/main",
        "wordpress_export_to_server__export_home": "https://wuk-experiments.test",
        "timezone_string": "Europe/Berlin",
        "date_format": "d. F Y",
        "time_format": "H:i",
        "start_of_week": "1",
        "show_on_front": "page",
        "page_on_front": "6"
      }
    },
    {
      "step": "defineWpConfigConsts",
      "consts": {
        "UPLOADS": "wp-content/uploads",
        "CORE_UPGRADE_SKIP_NEW_BUNDLED": true
      }
    },
    {
      "step": "runPHP",
      "code": "<?php require '/wordpress/wp-load.php'; add_filter( 'import_allow_fetch_attachments', '__return_true' );"
    },
    {
      "step": "login"
    },
    {
      "step": "wp-cli",
      "command": " wp post delete 1 2 3 --force",
      "progress": {
        "weight": 10,
        "caption": "Deleting the WordPress default content."
      }
    },
    {
      "step": "wp-cli",
      "command": " wp plugin delete hello-dolly",
      "progress": {
        "weight": 10,
        "caption": "Deleting the WordPress default plugins."
      }
    },
    {
      "step": "installPlugin",
      "pluginData": {
        "resource": "wordpress.org/plugins",
        "slug": "create-block-theme"
      },
      "options": {
        "activate": true
      }
    },
    {
      "step": "installTheme",
      "themeData": {
        "resource": "git:directory",
        "url": "https://github.com/carstingaxion/wuk-experiments",
        "ref": "main",
        "refType": "branch",
        "path": "wp-content/themes/wuk-experiments"
      },
      "options": {
        "activate": true,
        "targetFolderName": "wuk-experiments"
      },
      "progress": {
        "caption": "Installing theme from GitHub: carstingaxion/wuk-experiments (main)"
      }
    },
    {
      "step": "writeFile",
      "path": "/wordpress/wp-content/mu-plugins/wordpress-export-to-server.php",
      "data": {
        "resource": "url",
        "url": "https://raw.githubusercontent.com/carstingaxion/wordpress-export-to-server/main/wordpress-export-to-server.php"
      }
    },
    {
        "step": "importWxr",
        "file": {
            "resource": "url",
            "url": "https://raw.githubusercontent.com/carstingaxion/wuk-experiments/refs/heads/main/wp-content/wuk-experiments-main/export.xml"
        }
    }
  ]
}
